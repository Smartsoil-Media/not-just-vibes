{
  "name": "@njv/server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:check": "tsx scripts/check-migrations.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.14.0",
    "@njv/shared": "workspace:*",
    "@njv/skills-catalog": "workspace:*",
    "@njv/templates": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.12",
    "nanoid": "^5.0.9",
    "openai": "^4.73.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
